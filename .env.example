APP_NAME=TalkSync API
ENVIRONMENT=development
API_PREFIX=/api
WS_PATH=/ws/realtime
DEFAULT_AI_TIER=free

OPENAI_API_KEY=
REDIS_URL=redis://localhost:6379/0
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

SOURCE_LANGUAGE=en
TARGET_LANGUAGES=["hi","pa"]
SUPPORTED_LANGUAGES=["en","hi","pa"]
SUPPORTED_CHANNELS=["web","zoom","google_meet","microsoft_teams","zoho_meeting"]
STT_MODEL=gpt-4o-mini-transcribe
TRANSLATION_MODEL=gpt-5-mini
TTS_MODEL=gpt-4o-mini-tts
TTS_VOICE=alloy
TRANSCRIPT_PHASE_TWO_ENABLED=false
VOICE_SELECTION_PHASE_TWO_ENABLED=false
